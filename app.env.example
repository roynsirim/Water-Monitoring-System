# ─── Water Monitoring System ────────────────────────────────────────────────
# Copy this file to `app.env` and edit values for your deployment.
# All values can also be overridden by real environment variables; the OS env
# takes precedence over values in this file.

# ─── Server ─────────────────────────────────────────────────────────────────
WMS_HOST=0.0.0.0
WMS_PORT=8080

# ─── Database ───────────────────────────────────────────────────────────────
# Built-in JSON store is the default. SQL drivers can be plugged in later
# without changing the application code (WMS_DB_DRIVER + WMS_DB_DSN).
WMS_DB_DRIVER=json
WMS_DB_PATH=./data/water.json
# Example for a future Postgres driver:
# WMS_DB_DRIVER=postgres
# WMS_DB_DSN=postgres://wms:wms@localhost:5432/wms?sslmode=disable

# ─── Frontend ───────────────────────────────────────────────────────────────
WMS_FRONTEND_PATH=./frontend/index.html

# ─── Auth ───────────────────────────────────────────────────────────────────
# Generate a strong 32+ byte secret: `openssl rand -hex 32`
WMS_JWT_SECRET=replace-me-with-a-long-random-secret
WMS_SESSION_TTL=12h
WMS_BCRYPT_COST=12
WMS_ALLOW_REGISTRATION=false

# Legacy machine-to-machine API key (optional). When set, requests presenting
# X-API-Key: <value> bypass session auth (useful for cron / Prometheus).
WMS_API_KEY=

# Initial admin (only used on first start, when the user store is empty).
# CHANGE the password on first login.
WMS_ADMIN_EMAIL=admin@example.com
WMS_ADMIN_PASSWORD=ChangeMe!123

# ─── External Integrations (optional) ───────────────────────────────────────
WMS_EEMON_ENABLED=false
WMS_EEMON_BASE_URL=
WMS_EEMON_USERNAME=
WMS_EEMON_PASSWORD=
WMS_EEMON_SITE_ID=stocksbridge

WMS_TREND_ENABLED=false
WMS_TREND_BASE_URL=
WMS_TREND_API_KEY=
